{
    "name": "szybko",
    "version": "1.0.0",
    "private": true,
    "packageManager": "pnpm@10.34.3",
    "scripts": {
        "dev": "pnpm build:plugins && concurrently -n 🖥️,🧩 -c cyan,green \"pnpm run dev:desktop\" \"pnpm run dev:plugins\"",
        "build": "pnpm build:plugins && pnpm -r build",
        "build:plugins": "pnpm --filter './plugins/**' build",
        "dev:desktop": "pnpm --filter @szybko/desktop dev",
        "dev:plugins": "pnpm --filter './plugins/**' dev",
        "typecheck": "pnpm -r run typecheck",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "dependencies": {
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "tailwindcss": "^4.3.2"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^9.1.0",
        "@eslint-react/eslint-plugin": "^5.9",
        "@tailwindcss/vite": "^4.3.2",
        "@types/node": "^26.1.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "concurrently": "^10.0.3",
        "eslint": "^10.0",
        "eslint-plugin-format": "^2.0",
        "eslint-plugin-react-refresh": "^0.5",
        "eslint-plugin-tailwindcss": "^4.0.5",
        "typescript": "^6.0.3",
        "vite": "^8.1.2"
    }
}

{
    "name": "szybko",
    "version": "1.0.0",
    "private": true,
    "packageManager": "pnpm@10.34.3",
    "scripts": {
        "dev": "pnpm build:plugins && pnpm --filter @szybko/desktop dev",
        "build": "pnpm build:plugins && pnpm -r build",
        "build:plugins": "pnpm --filter './plugins/**' build",
        "typecheck": "pnpm -r run typecheck",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^9.1.0",
        "@eslint-react/eslint-plugin": "^5.9",
        "@tailwindcss/vite": "^4.3.2",
        "@vitejs/plugin-react": "^6.0.3",
        "eslint": "^10.0",
        "eslint-plugin-format": "^2.0",
        "eslint-plugin-react-refresh": "^0.5",
        "eslint-plugin-tailwindcss": "^4.0.5",
        "tailwindcss": "^4.3.2",
        "typescript": "^6.0.3"
    }
}

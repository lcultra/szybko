{
    "name": "@szybko/plugin-preferences",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build --config vite.preload.config.ts && vite build && cp plugin.json dist/",
        "typecheck": "tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
    },
    "dependencies": {
        "@szybko/shared": "workspace:*",
        "@vitejs/plugin-react": "^6.0.3",
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    },
    "devDependencies": {
        "@types/node": "^26.1.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "typescript": "^6.0",
        "vite": "^8.1.2"
    }
}
